        <ImageButton
            android:id="@+id/mybtn2"
            android:layout_width="200px"
            android:layout_height="200px"
            android:background="@drawable/rounded_btn"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_margin="40dp"
            android:src="@drawable/object" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@id/mybtn2"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="-140dp"
            android:text="Object Detection"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:layout_centerHorizontal="true"/>

        <ImageButton
            android:id="@+id/mybtn3"
            android:layout_width="200px"
            android:layout_height="200px"
            android:background="@drawable/rounded_btn"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="40dp"
            android:src="@drawable/scan_text"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@id/mybtn3"
            android:layout_marginBottom="-140dp"
            android:text="Scan Text"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:layout_alignParentEnd="true"
            android:layout_marginRight="45dp"/>

        <ImageButton
            android:id="@+id/mybtn4"
            android:layout_width="200px"
            android:layout_height="200px"
            android:background="@drawable/rounded_btn"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:layout_margin="40dp"
            android:src="@drawable/document" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@id/mybtn4"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="-140dp"
            android:text="Documents"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:layout_marginLeft="40dp"/>
</RelativeLayout>